#--------------------------------------------------------------------
# ENVIRONMENT
#--------------------------------------------------------------------
CI_ENVIRONMENT = development
CI_DEBUG = false

#--------------------------------------------------------------------
# APP
#--------------------------------------------------------------------
app.baseURL    = 'http://localhost:8080/'
app.forceGlobalSecureRequests = false

#--------------------------------------------------------------------
# DATABASE - SQLite
#--------------------------------------------------------------------
database.default.DBDriver   = SQLite3
database.default.database   = C:\Users\User\Desktop\temp\Ecom_CI4\writable\database.sqlite
database.default.DBDebug    = false

#--------------------------------------------------------------------
# SESSIONS
#--------------------------------------------------------------------
app.sessionDriver    = 'CodeIgniter\Session\Handlers\FileSessionHandler'
app.sessionSavePath  = C:\Users\User\Desktop\temp\Ecom_CI4\writable\session
app.sessionCookieName = ci_session
app.sessionExpiration = 7200

#--------------------------------------------------------------------
# ADMIN CREDENTIALS  (checked FIRST before database)
#--------------------------------------------------------------------
ADMIN_EMAIL    = admin@shop.com
ADMIN_PASSWORD = Admin@1234

#--------------------------------------------------------------------
# JWT
#--------------------------------------------------------------------
JWT_SECRET     = my_super_secret_jwt_key_2024
JWT_EXPIRE     = 86400

#--------------------------------------------------------------------
# PAYMENTS
#--------------------------------------------------------------------
PAYMENT_PROVIDER       = mockpay
PAYMENT_WEBHOOK_SECRET =
PAYMENT_CURRENCY       = USD

#--------------------------------------------------------------------
# MAILER
#--------------------------------------------------------------------
MAIL_FROM_EMAIL   =
MAIL_FROM_NAME    = ShopCI4
MAIL_PROTOCOL     = smtp
MAIL_SMTP_HOST    =
MAIL_SMTP_PORT    = 587
MAIL_SMTP_USER    =
MAIL_SMTP_PASS    =
MAIL_SMTP_CRYPTO  = tls
